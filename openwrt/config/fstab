# cat /etc/config/fstab

config global
        option anon_swap '1'
        option anon_mount '1'
        option auto_swap '1'
        option auto_mount '1'
        option delay_root '5'
        option check_fs '1'

config mount
        option enabled '1'
        option label '1TB_home'
        option target '/root'

config mount
        option enabled '1'
        option label '512GB_mbana'
        option target '/mnt/mbana'
