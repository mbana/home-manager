[alias]
	d = "diff"
	dc = "diff --cached"
	ll = "log -n1"
	s = "status"

[color]
	advice = "true"
	status = "always"
	ui = "true"

[commit]
	gpgSign = true
	verbose = true

[core]
	editor = "code --wait --new-window"
	hideDotFiles = "false"
	ignorecase = "false"

[filter "lfs"]
	clean = "git-lfs clean -- %f"
	process = "git-lfs filter-process"
	required = true
	smudge = "git-lfs smudge -- %f"

[gpg]
	format = "ssh"

#[gpg "ssh"]
	program = "/nix/store/s29f95k50f7rmydgicz6rzls6f0xmhnv-openssh-10.2p1/bin/ssh-keygen"

[init]
	defaultBranch = "main"

[tag]
	gpgSign = true

[url "git@github.com:"]
	insteadOf = "https://github.com/"

[url "git@gitlab.com:"]
	insteadOf = "https://gitlab.com/"

[user]
	email = "mohamed.omar.bana@gmail.com"
	name = "Mohamed Bana"
	signingKey = "~/.ssh/id_ed25519.pub"
